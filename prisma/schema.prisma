generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String        @id @default(cuid())
  email             String        @unique
  name              String?
  password          String
  isAdmin           Boolean       @default(false)
  address           String?
  paymentInfo       String?
  stripeCustomerId  String?
  createdAt         DateTime      @default(now())
  spots             AuctionSpot[]
  passwordResetToken String?
  passwordResetExpiry DateTime?
}

model InventoryItem {
  id           String        @id @default(cuid())
  name         String
  tier         String
  qty          Int
  cost         Float
  resellMin    Float
  resellMax    Float
  note         String?
  imageUrl     String?
  shippingCost Float         @default(10.0)
  auctionItems AuctionItem[]
}

model Auction {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      String        @default("active")
  spotPrice   Float
  totalSpots  Int
  spinSeed     String?
  shippingRate Float         @default(8.0)
  createdAt    DateTime      @default(now())
  completedAt  DateTime?
  expiresAt    DateTime?
  items       AuctionItem[]
  spots       AuctionSpot[]
}

model AuctionItem {
  id         String        @id @default(cuid())
  auctionId  String
  auction    Auction       @relation(fields: [auctionId], references: [id])
  itemId     String
  item       InventoryItem @relation(fields: [itemId], references: [id])
  quantity   Int           @default(1)
  spotNumber Int?
}

model AuctionSpot {
  id             String   @id @default(cuid())
  auctionId      String
  auction        Auction  @relation(fields: [auctionId], references: [id])
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  spotNumber     Int
  paymentId      String?
  paymentMethod  String?
  paid           Boolean  @default(false)
  assignedItemId    String?
  shipped           Boolean  @default(false)
  trackingNumber    String?
  shippingPaid      Boolean  @default(false)
  shippingPaymentId String?
  shippingCost      Float?
  createdAt         DateTime @default(now())
}
